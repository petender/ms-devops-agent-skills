---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { CATEGORY_LABELS } from '@/content/config';
import { CATEGORY_BADGE } from '@/lib/category-classes';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const skills = await getCollection('skills');
  return skills.map((skill) => ({ params: { slug: skill.slug }, props: { skill } }));
}

interface Props { skill: CollectionEntry<'skills'>; }
const { skill } = Astro.props;
const d = skill.data;
const slug = skill.slug;
const t = d.trainer;
import { base } from '@/lib/url';
const totalExerciseMin = (t?.exercises ?? []).reduce((s, e) => s + e.durationMinutes, 0);
---
<BaseLayout title={`Trainer: ${d.name}`} description={`Lesson plan for “${d.name}”.`}>
  <article class="mx-auto max-w-4xl px-4 py-10">
    <nav class="mb-4 text-sm text-ink-500 dark:text-ink-400">
      <a href={`${base}trainer`} class="hover:text-indigo-600 dark:hover:text-indigo-300">Trainer</a>
      <span class="mx-1">/</span>
      <span class="text-ink-700 dark:text-ink-200">{d.name}</span>
    </nav>

    <div class="mb-3 flex flex-wrap items-center gap-2 text-xs">
      <span class:list={["badge", CATEGORY_BADGE[d.category]]}>{CATEGORY_LABELS[d.category]}</span>
      <span class="text-ink-500 dark:text-ink-400">·</span>
      <span class="capitalize text-ink-700 dark:text-ink-300">{d.level}</span>
      <span class="text-ink-500 dark:text-ink-400">·</span>
      <span class="text-ink-700 dark:text-ink-300">{d.estimatedMinutes} min skill · {t?.demoScriptMinutes ?? 0} min demo · {totalExerciseMin} min exercises</span>
    </div>
    <h1 class="text-3xl font-bold text-ink-900 dark:text-ink-100 sm:text-4xl">{d.name}</h1>
    <p class="mt-3 text-lg text-ink-600 dark:text-ink-300">{d.description}</p>
    <div class="mt-4">
      <a href={`${base}skills/${slug}/`} class="btn">Open skill page →</a>
    </div>

    {!t ? (
      <p class="mt-10 rounded-2xl border border-dashed border-ink-300 p-6 text-center text-ink-500 dark:border-ink-700 dark:text-ink-400">
        This skill does not have trainer notes yet. <a class="text-indigo-600 hover:underline dark:text-indigo-300" href="https://github.com/petender/ms-devops-agent-skills/blob/main/CONTRIBUTING.md">Contribute one</a>.
      </p>
    ) : (
      <div class="prose-devops mt-10">
        <h2>Learning objectives</h2>
        <ul>
          {t.learningObjectives.map((o) => <li>{o}</li>)}
        </ul>

        {t.prerequisites.length > 0 && (
          <>
            <h2>Prerequisites</h2>
            <ul>
              {t.prerequisites.map((p) => <li>{p}</li>)}
            </ul>
          </>
        )}

        {t.slideTalkingPoints.length > 0 && (
          <>
            <h2>Slide talking points</h2>
            <ol>
              {t.slideTalkingPoints.map((p) => <li>{p}</li>)}
            </ol>
          </>
        )}

        {t.demoScriptMinutes > 0 && (
          <>
            <h2>Live demo script ({t.demoScriptMinutes} min)</h2>
            <p>Walk through the skill live using the agent of your choice. Reference the <a href={`${base}skills/${slug}/`}>skill instructions</a> and highlight where the model reads context, what it emits, and where a human should intervene.</p>
          </>
        )}

        {t.exercises.length > 0 && (
          <>
            <h2>Hands-on exercises</h2>
            {t.exercises.map((e, i) => (
              <div class="mb-4 rounded-lg border border-ink-200 p-4 dark:border-ink-800">
                <h3 class="!mt-0">Exercise {i + 1}: {e.title} <span class="text-sm font-normal text-ink-500 dark:text-ink-400">({e.durationMinutes} min)</span></h3>
                <p>{e.summary}</p>
              </div>
            ))}
          </>
        )}

        {t.commonPitfalls.length > 0 && (
          <>
            <h2>Common pitfalls</h2>
            <ul>
              {t.commonPitfalls.map((p) => <li>{p}</li>)}
            </ul>
          </>
        )}

        {t.discussionQuestions.length > 0 && (
          <>
            <h2>Discussion questions</h2>
            <ol>
              {t.discussionQuestions.map((q) => <li>{q}</li>)}
            </ol>
          </>
        )}
      </div>
    )}
  </article>
</BaseLayout>
