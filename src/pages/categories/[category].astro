---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SkillCard from '@/components/SkillCard.astro';
import { CATEGORIES, CATEGORY_LABELS } from '@/content/config';
import { base } from '@/lib/url';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const skills = await getCollection('skills');
  return CATEGORIES.map((category) => ({
    params: { category },
    props: { category, skills: skills.filter((s) => s.data.category === category) },
  }));
}

const { category, skills } = Astro.props as { category: (typeof CATEGORIES)[number]; skills: any[] };
---
<BaseLayout title={CATEGORY_LABELS[category]}>
  <section class="mx-auto max-w-7xl px-4 py-10">
    <a href={base} class="text-sm text-indigo-600 hover:underline dark:text-indigo-300">← Back to catalog</a>
    <h1 class="mt-3 text-3xl font-bold text-ink-900 dark:text-ink-100">{CATEGORY_LABELS[category]}</h1>
    <p class="mt-1 text-ink-600 dark:text-ink-300">{skills.length} skill{skills.length === 1 ? '' : 's'}</p>
    <div class="mt-8 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {skills.map((s) => <SkillCard skill={s} />)}
    </div>
  </section>
</BaseLayout>
