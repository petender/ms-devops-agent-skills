---
import BaseLayout from '@/layouts/BaseLayout.astro';
import SkillCard from '@/components/SkillCard.astro';
import CollectionTile from '@/components/CollectionTile.astro';
import { getCollection } from 'astro:content';
import collections from '@/data/collections.json';

const skills = await getCollection('skills');
const bySlug = new Map(skills.map((s) => [s.slug, s]));

const enriched = collections.map((c) => ({
  ...c,
  entries: c.skills.map((sl) => bySlug.get(sl)).filter(Boolean) as typeof skills,
}));
---
<BaseLayout title="Collections" description="Curated ordered sequences of DevOps agent skills.">
  <section class="mx-auto max-w-7xl px-4 py-10">
    <h1 class="text-3xl font-bold text-ink-900 dark:text-ink-100">Collections</h1>
    <p class="mt-1 max-w-2xl text-ink-600 dark:text-ink-300">
      Curated, ordered sequences of skills. Follow one end-to-end in a workshop, or send learners home with a set for self-study.
    </p>

    <div class="mt-8 grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
      {enriched.map((c) => (
        <CollectionTile slug={c.slug} name={c.name} description={c.description} count={c.entries.length} color={c.color as 'teal' | 'indigo' | 'amber' | 'red'} />
      ))}
    </div>

    {enriched.map((c) => (
      <section id={c.slug} class="mt-12">
        <h2 class="text-2xl font-semibold text-ink-900 dark:text-ink-100">{c.name}</h2>
        <p class="mt-1 text-ink-600 dark:text-ink-300">{c.description}</p>
        <ol class="mt-6 grid grid-cols-1 gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {c.entries.map((s, i) => (
            <li class="relative">
              <span class="absolute -left-2 -top-2 z-10 inline-flex h-7 w-7 items-center justify-center rounded-full bg-indigo-600 text-xs font-bold text-white">{i + 1}</span>
              <SkillCard skill={s} />
            </li>
          ))}
        </ol>
      </section>
    ))}
  </section>
</BaseLayout>
