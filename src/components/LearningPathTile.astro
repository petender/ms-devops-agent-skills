---
interface Props {
  slug: string;
  name: string;
  description: string;
  count: number;
  color: 'teal' | 'indigo' | 'amber' | 'red';
}

const { slug, name, description, count, color } = Astro.props;
import { base } from '@/lib/url';

const gradient = {
  teal:   'from-teal-500/20 to-teal-500/5 border-teal-500/30 hover:border-teal-500',
  indigo: 'from-indigo-500/20 to-indigo-500/5 border-indigo-500/30 hover:border-indigo-500',
  amber:  'from-amber-500/20 to-amber-500/5 border-amber-500/30 hover:border-amber-500',
  red:    'from-red-500/20 to-red-500/5 border-red-500/30 hover:border-red-500',
}[color];
---
<a href={`${base}?path=${slug}`} class:list={["group rounded-2xl border bg-gradient-to-br p-5 transition", gradient]}>
  <div class="flex items-start justify-between gap-3">
    <div>
      <h3 class="text-base font-semibold text-ink-900 group-hover:text-indigo-600 dark:text-ink-100 dark:group-hover:text-indigo-300">{name}</h3>
      <p class="mt-1 text-sm text-ink-600 dark:text-ink-300">{description}</p>
    </div>
    <span class="rounded-full bg-white px-2.5 py-0.5 text-xs font-semibold text-ink-700 dark:bg-ink-800 dark:text-ink-200">{count}</span>
  </div>
  <p class="mt-3 text-xs font-semibold text-ink-500 group-hover:text-indigo-600 dark:text-ink-400 dark:group-hover:text-indigo-300">Browse path →</p>
</a>
